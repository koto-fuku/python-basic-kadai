      "source": [
        "# 消費税を計算する関数\n",
        "def calculate_tax(price, tax_rate):\n",
        "    total = price + (price * tax_rate / 100)\n",
        "    return total\n",
        "\n",
        "# 第1引数：商品金額110円\n",
        "# 第2引数：消費税率10%\n",
        "result = calculate_tax(110, 10)\n",
        "\n",
        "# 結果を出力\n",
        "print(result)"
      ]
    }
