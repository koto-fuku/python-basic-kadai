      "source": [
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self):\n",
        "        print(\"名前:\", self.name)\n",
        "        print(\"年齢:\", str(self.age) + \"歳\")\n",
        "\n",
        "\n",
        "# インスタンス作成\n",
        "person = Human(\"KOTOMI\", 20)\n",
        "\n",
        "# メソッド実行\n",
        "person.printinfo()"
      ]
    }
  ],
